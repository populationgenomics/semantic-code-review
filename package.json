{
  "name": "semantic-code-review-frontend",
  "version": "0.4.0",
  "private": true,
  "description": "Frontend assets for the scr diff viewer. Compiled to viewer/assets/annotations.js and inlined into the HTML by render_html.py.",
  "scripts": {
    "build": "npm run typecheck && npm run bundle",
    "bundle": "esbuild semantic_code_review/viewer/assets/boot.ts --bundle --format=iife --target=es2020 --outfile=semantic_code_review/viewer/assets/viewer.js",
    "typecheck": "tsc --noEmit",
    "build:watch": "npm run bundle -- --watch",
    "test:js": "vitest run",
    "test:js:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@types/node": "22.10.2",
    "esbuild": "^0.28.0",
    "jsdom": "25.0.1",
    "typescript": "5.7.3",
    "vitest": "2.1.9"
  }
}
