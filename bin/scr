#!/usr/bin/env bash
# Bootstrap wrapper for the `scr` CLI when packaged as a Claude Code plugin.
#
# Responsibilities, in order of importance:
#
# 1. Preflight system dependencies. python3 (>= 3.11) and git are hard
#    requirements; gh and rg are optional and we only warn if missing.
# 2. Maintain a per-plugin virtualenv under $CLAUDE_PLUGIN_DATA/venv. Two
#    cache keys gate the work:
#      - deps stamp : sha256(requirements.lock)
#                     → gates the slow hashed dependency install.
#      - pkg stamp  : the target version string
#                     → gates only the fast scr wheel install from PyPI.
#    A version bump reinstalls just the scr wheel in ~1s instead of
#    re-running the full dependency install.
# 3. Exec the real `scr` out of that venv, passing through all argv.
#
# The scr package (with its prebuilt viewer.js bundle) is installed from
# PyPI at the version pinned in the plugin tree's pyproject.toml, so the
# git checkout is a thin launcher, not a build tree — no Node, npm, or
# build backend is ever needed. Third-party deps are hash-pinned via
# requirements.lock; scr itself is version-pinned from its own PyPI project
# (Trusted Publishing) and installed --no-deps against those deps.
#
# The script is idempotent and cheap on the hot path (one sha256 check, one
# stamp read, one exec) — the expensive bootstrap only runs when something
# has actually changed.

set -eu -o pipefail

die() { printf 'scr: %s\n' "$*" >&2; exit 1; }
warn() { printf 'scr: warning: %s\n' "$*" >&2; }

# --- locate plugin tree + data dir ------------------------------------------

# $CLAUDE_PLUGIN_ROOT / $CLAUDE_PLUGIN_DATA are set by Claude Code when invoking
# plugin bin/ scripts. Fall back sensibly when run standalone (e.g. during
# development from inside the repo).
if [ -z "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  CLAUDE_PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
fi
if [ -z "${CLAUDE_PLUGIN_DATA:-}" ]; then
  CLAUDE_PLUGIN_DATA="${XDG_DATA_HOME:-$HOME/.local/share}/claude-plugins/scr"
fi

mkdir -p "$CLAUDE_PLUGIN_DATA"

VENV="$CLAUDE_PLUGIN_DATA/venv"
PYPROJECT="$CLAUDE_PLUGIN_ROOT/pyproject.toml"
LOCKFILE="$CLAUDE_PLUGIN_ROOT/requirements.lock"

[ -f "$PYPROJECT" ] || die "pyproject.toml missing from plugin tree at $PYPROJECT"
[ -f "$LOCKFILE" ]  || die "requirements.lock missing from plugin tree at $LOCKFILE"

# --- preflight --------------------------------------------------------------

need_python=1
if command -v python3 >/dev/null 2>&1; then
  ver=$(python3 -c 'import sys; print("%d.%d" % sys.version_info[:2])' 2>/dev/null || echo "0.0")
  major=${ver%%.*}
  minor=${ver#*.}
  if [ "$major" -gt 3 ] || { [ "$major" -eq 3 ] && [ "$minor" -ge 11 ]; }; then
    need_python=0
  fi
fi
[ "$need_python" -eq 0 ] || die "python3 >= 3.11 is required but missing or too old"

command -v git >/dev/null 2>&1 || die "git is required but not on PATH"

if ! command -v gh >/dev/null 2>&1; then
  warn "gh not found — 'scr fetch' on a GitHub PR URL will fail. /review on local diffs still works."
fi
if ! command -v rg >/dev/null 2>&1; then
  warn "ripgrep (rg) not found — falling back to 'git grep' for LLM tool-use searches."
fi

# --- resolve target version -------------------------------------------------

# The plugin installs this exact scr version from PyPI, so the cloned
# slash-command definitions and the installed CLI always move together.
# tomllib is stdlib on the python3 >= 3.11 required above.
VERSION=$(python3 -c 'import tomllib,sys; print(tomllib.load(open(sys.argv[1],"rb"))["project"]["version"])' "$PYPROJECT") \
  || die "could not read project version from $PYPROJECT"
[ -n "$VERSION" ] || die "empty project version in $PYPROJECT"

# --- venv install (split-stamp, idempotent) -------------------------------

hash_files() {
  local shacmd
  if command -v shasum >/dev/null 2>&1; then shacmd="shasum -a 256";
  else shacmd="sha256sum"; fi
  $shacmd "$@" | awk '{print $1}' | $shacmd | awk '{print $1}'
}

deps_hash=$(hash_files "$LOCKFILE")
deps_stamp="$CLAUDE_PLUGIN_DATA/deps-${deps_hash}"
pkg_stamp="$CLAUDE_PLUGIN_DATA/pkg-${VERSION}"

did_install=0

# Slow path: lockfile changed (or fresh install). --require-hashes makes pip
# refuse any dependency whose on-disk SHA-256 doesn't match requirements.lock,
# so a compromised release, typo-squat, or mirror MITM fails the install
# rather than silently landing. scr's own wheel is installed below.
if [ ! -x "$VENV/bin/python" ] || [ ! -f "$deps_stamp" ]; then
  printf 'scr: installing python dependencies under %s (first run / lockfile changed)\n' "$VENV" >&2
  if [ -d "$VENV" ]; then
    rm -rf "$VENV"
  fi
  python3 -m venv "$VENV"
  # shellcheck disable=SC1090,SC1091
  "$VENV/bin/pip" install --quiet --require-hashes -r "$LOCKFILE"
  find "$CLAUDE_PLUGIN_DATA" -maxdepth 1 -name 'deps-*' -print0 2>/dev/null | xargs -0 rm -f || true
  printf '%s\n' "$deps_hash" > "$deps_stamp"
  # Fresh venv → force the scr reinstall below regardless of pkg stamp
  # (the venv has no `scr` binary yet).
  find "$CLAUDE_PLUGIN_DATA" -maxdepth 1 -name 'pkg-*' -print0 2>/dev/null | xargs -0 rm -f || true
  did_install=1
fi

# Fast path: the pinned version changed but the lockfile didn't — only the
# scr wheel needs reinstalling. --no-deps because requirements.lock already
# installed the full, hashed dependency closure above; pip must not resolve
# (and unpin) anything here. The wheel carries the prebuilt viewer.js.
if [ ! -x "$VENV/bin/scr" ] || [ ! -f "$pkg_stamp" ]; then
  if [ "$did_install" -eq 0 ]; then
    printf 'scr: installing scr %s from PyPI\n' "$VERSION" >&2
  fi
  "$VENV/bin/pip" install --quiet --no-deps "semantic-code-review==$VERSION" \
    || die "could not install semantic-code-review==$VERSION from PyPI (is the release published?)"
  find "$CLAUDE_PLUGIN_DATA" -maxdepth 1 -name 'pkg-*' -print0 2>/dev/null | xargs -0 rm -f || true
  printf '%s\n' "$VERSION" > "$pkg_stamp"
  did_install=1
fi

if [ "$did_install" -eq 1 ]; then
  # Clear stamps and build dirs from older bootstrap formats so they don't
  # accumulate (pre-split `installed-*`, and the local-build `node-built-*`
  # stamp + its viewer-build output dir).
  find "$CLAUDE_PLUGIN_DATA" -maxdepth 1 \( -name 'installed-*' -o -name 'node-built-*' \) -print0 2>/dev/null | xargs -0 rm -f || true
  rm -rf "$CLAUDE_PLUGIN_DATA/viewer-build" 2>/dev/null || true
  printf 'scr: ready\n' >&2
fi

exec "$VENV/bin/scr" "$@"
