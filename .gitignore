# TypeScript build artifacts. The viewer is bundled by esbuild
# (boot.ts → viewer.js as a single IIFE); tsc only type-checks (no
# emit). viewer.js is NOT committed: release.yml builds it into the
# published wheel as package_data, and the plugin installs that wheel
# from PyPI. annotations.js was the retired pre-migration emit and is
# ignored defensively so a stray rebuild of an older checkout can't
# smuggle a stale copy back into the tree.
node_modules/
semantic_code_review/viewer/assets/viewer.js
semantic_code_review/viewer/assets/annotations.js
semantic_code_review/viewer/assets/*.d.ts
# types.d.ts is hand-authored (the viewer data contract), not a tsc emit.
!semantic_code_review/viewer/assets/types.d.ts
.tsbuildinfo
playwright-report/
test-results/
