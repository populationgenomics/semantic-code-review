# TypeScript build artifacts. The viewer is bundled by esbuild (boot.ts
# → viewer.js); tsc only type-checks. annotations.js is the retired
# pre-migration emit name; ignoring it defensively so a stray rebuild
# of an older checkout doesn't get committed.
node_modules/
semantic_code_review/viewer/assets/viewer.js
semantic_code_review/viewer/assets/annotations.js
semantic_code_review/viewer/assets/*.d.ts
# types.d.ts is hand-authored (the viewer data contract), not a tsc emit.
!semantic_code_review/viewer/assets/types.d.ts
.tsbuildinfo
playwright-report/
test-results/
uv.lock
