# TypeScript build artifacts — annotations.ts is the source of truth;
# annotations.js is produced by `tsc` (either via `npm run build` or
# the bin/scr bootstrap) and inlined into the viewer HTML.
node_modules/
# esbuild emits a single bundled IIFE from boot.ts as the entry; tsc
# only type-checks (no emit). render_html.py inlines the bundle.
semantic_code_review/viewer/assets/viewer.js
semantic_code_review/viewer/assets/*.d.ts
# types.d.ts is hand-authored (the viewer data contract), not a tsc emit.
!semantic_code_review/viewer/assets/types.d.ts
.tsbuildinfo
playwright-report/
test-results/
uv.lock
