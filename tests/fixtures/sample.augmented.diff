#scr: scr-file-summary: Adds paginate() helper and threads page/size through list_users.
#scr: scr-file-role: modified
#scr: scr-file-lang: python
@@ -1,2 +1,7 @@
-def list_users(db):
-    return db.query("SELECT * FROM users")
+def paginate(query, page, size):
+    offset = page * size
+    return f"{query} LIMIT {size} OFFSET {offset}"
+
+def list_users(db, page=0, size=50):
+    sql = paginate("SELECT * FROM users", page, size)
+    return db.query(sql)
#scr: scr-hunk-intent: Pagination is introduced for /users; the mechanism is extracted into a reusable helper so
