<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% if session_endpoint %}<meta name="scr-session-endpoint" content="{{ session_endpoint|e }}">{% endif %}
  <title>{{ pr_title|e }}</title>
  {# highlight.js is always loaded from vendored, version-pinned bytes — see
     semantic_code_review/viewer/assets/vendor/VENDOR.md for provenance +
     SHA-256 hashes. We no longer fetch from a CDN to eliminate a supply-
     chain hop. The dark stylesheet is gated by prefers-color-scheme so
     both themes ship in a single HTML file. #}
  <style media="(prefers-color-scheme: dark)">{{ hljs_css_dark|safe }}</style>
  <style media="(prefers-color-scheme: light)">{{ hljs_css_light|safe }}</style>
  <style>{{ viewer_css|safe }}</style>
</head>
<body>
  <header class="pr-bar">
    <div class="pr-title">
      {{ pr_title|e }}
      <span class="pr-meta">{{ pr_meta|e }}</span>
    </div>
    <div class="fold-slider" role="tablist" aria-label="Fold level">
      <button data-fold="files" title="Collapse to files (1)">Files</button>
      <button data-fold="hunks" title="Collapse to hunks (2)">Hunks</button>
      <button data-fold="segments" title="Collapse to segments (3)">Segments</button>
      <button data-fold="off" title="Fully expanded (4)">Off</button>
    </div>
    <button id="reset-btn" class="reset-btn" title="Clear per-region overrides">Reset</button>
    <button id="help-btn" class="help-btn" title="Help (?)" aria-label="Help">?</button>
  </header>

  <main id="app"></main>

  <footer id="status-bar" class="status-bar"></footer>

  <div id="help-overlay" class="help-overlay hidden" role="dialog" aria-label="Help">
    <div class="help-card">
      <h3>Keyboard shortcuts</h3>
      <p><kbd>1</kbd> fold to files · <kbd>2</kbd> hunks · <kbd>3</kbd> segments · <kbd>4</kbd> expand</p>
      <p><kbd>?</kbd> toggle this help · <kbd>Esc</kbd> close</p>
      <p>Click any region header to toggle its fold state independently.
         "Reset" clears per-region overrides and applies the global fold level.</p>
    </div>
  </div>

  <script>{{ hljs_js|safe }}</script>
  <script type="application/json" id="scr-data">{{ data_json|safe }}</script>
  <script>{{ viewer_js|safe }}</script>
</body>
</html>
